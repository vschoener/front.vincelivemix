    "eslint": "^10.0.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "husky": "^9.1.7",

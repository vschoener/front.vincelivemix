# Copy to `.env` and adjust. With direnv + `.envrc`, variables load when you `cd` into the repo
# (run `direnv allow` once after cloning). CI/production set the same names in the host UI (e.g. Vercel).

# Real API origin — must not be the same URL as this Next app in dev (Next uses port 3001 by default; API often on 3000).
BACKEND_URL=http://localhost:3000
# Production (Vercel): use HTTPS only — http:// will often fail with DEPLOYMENT_NOT_FOUND.
# BACKEND_URL=https://backend.vincelivemix.fr

# Public origin of this Next app (RSS links, SSR axios base URL). Must match how you open the site locally.
HOST=http://localhost:3001

# Google Analytics / gtag measurement ID (optional; leave empty to disable)
# GOOGLE_TAG=

# i18next debug logging (optional)
LANG_DEBUG=false

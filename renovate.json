{
  "extends": [
    "config:recommended",
    "workarounds:nodeDockerVersioning",
    "workarounds:typesNodeVersioning"
  ],
  "labels": ["dependencies"],
  "assignees": ["vschoener"],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "ESLint major: manual review until jsx-eslint plugins publish ESLint 10 peers (see pnpm.overrides if using a git pin)",
      "matchPackageNames": ["eslint"],
      "matchUpdateTypes": ["major"],
      "groupName": "eslint-ecosystem",
      "automerge": false,
      "labels": ["eslint-major"]
    },
    {
      "groupName": "Next-and-React",
      "automerge": false,
      "labels": ["next-and-react"],
      "packagePatterns": ["next", "react"],
      "excludePackagePatterns": ["^eslint"]
    },
    {
      "groupName": "jest-dependencies",
      "automerge": false,
      "labels": ["jest-dependencies"],
      "packagePatterns": ["jest"]
    },
    {
      "description": "Git SHA in pnpm.overrides for eslint-plugin-react: no Renovate digest PRs (verify ESLint 10 compatibility before bumping)",
      "matchPackageNames": ["eslint-plugin-react"],
      "matchDepTypes": ["pnpm.overrides"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "updateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "groupName": "minors-update",
      "labels": ["dependencies-minors"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "labels": ["dev-dependencies"]
    },
    {
      "description": "Lint toolchain: single PR for eslint, eslint-config-next, plugins, typescript-eslint (overrides broad minors/devDeps rules)",
      "groupName": "eslint-ecosystem",
      "matchPackageNames": [
        "eslint",
        "eslint-config-next",
        "eslint-config-prettier",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "eslint-plugin-import",
        "eslint-plugin-jsx-a11y",
        "eslint-plugin-prettier",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks"
      ],
      "automerge": false,
      "labels": ["eslint-ecosystem"]
    },
    {
      "description": "package.json engines.node: only Node releases that are LTS (per Renovate node versioning)",
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["node"],
      "versioning": "node"
    },
    {
      "description": "asdf .tool-versions nodejs (depName node): only LTS releases",
      "matchManagers": ["asdf"],
      "matchDepNames": ["node"],
      "versioning": "node"
    },
    {
      "description": "Docker Hub node image commit subject (LTS filtering via workarounds:nodeDockerVersioning)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["node"],
      "commitMessageTopic": "Node.js"
    }
  ]
}

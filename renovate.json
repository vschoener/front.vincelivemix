{
  "extends": [
    "workarounds:nodeDockerVersioning",
    "workarounds:typesNodeVersioning"
  ],
  "labels": ["dependencies"],
  "assignees": ["vschoener"],
  "prConcurrentLimit": 1,
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "groupName": "Next-and-React",
      "automerge": false,
      "labels": ["next-and-react"],
      "packagePatterns": ["next", "react"]
    },
    {
      "groupName": "jest-dependencies",
      "automerge": false,
      "labels": ["jest-dependencies"],
      "packagePatterns": ["jest"]
    },
    {
      "groupName": "typescript-eslint",
      "automerge": false,
      "labels": ["typescript-eslint"],
      "packagePatterns": ["^@typescript-eslint"]
    },
    {
      "updateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "groupName": "minors-update",
      "labels": ["dependencies-minors"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "labels": ["dev-dependencies"]
    },
    {
      "description": "package.json engines.node: only Node releases that are LTS (per Renovate node versioning)",
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["node"],
      "versioning": "node"
    },
    {
      "description": "asdf .tool-versions nodejs (depName node): only LTS releases",
      "matchManagers": ["asdf"],
      "matchDepNames": ["node"],
      "versioning": "node"
    },
    {
      "description": "Docker Hub node image commit subject (LTS filtering via workarounds:nodeDockerVersioning)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["node"],
      "commitMessageTopic": "Node.js"
    }
  ]
}
